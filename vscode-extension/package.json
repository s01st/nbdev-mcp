{
  "name": "nbdev-mcp",
  "displayName": "nbdev MCP",
  "description": "VS Code extension for nbdev projects with MCP server integration",
  "version": "0.1.0",
  "publisher": "nbdev-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/nbdev-mcp"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "keywords": [
    "nbdev",
    "jupyter",
    "notebook",
    "mcp",
    "literate programming"
  ],
  "activationEvents": [
    "workspaceContains:**/settings.ini",
    "workspaceContains:**/_modidx.py"
  ],
  "main": "./out/extension.js",
    "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nbdev-explorer",
          "title": "nbdev",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "nbdev-explorer": [
        {
          "id": "nbdev-project",
          "name": "Project"
        },
        {
          "id": "nbdev-commands",
          "name": "Commands"
        },
        {
          "id": "nbdev-notebooks",
          "name": "Notebooks"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "nbdev-project",
        "contents": "No nbdev project detected.\n[Set Project](command:nbdev-mcp.setProject)"
      }
    ],
    "commands": [
      {
        "command": "nbdev-mcp.setProject",
        "title": "Set Active Project",
        "category": "nbdev",
        "icon": "$(folder-opened)"
      },
      {
        "command": "nbdev-mcp.currentProject",
        "title": "Show Current Project",
        "category": "nbdev",
        "icon": "$(info)"
      },
      {
        "command": "nbdev-mcp.export",
        "title": "Export Notebooks",
        "category": "nbdev",
        "icon": "$(export)"
      },
      {
        "command": "nbdev-mcp.prepare",
        "title": "Prepare (Export, Test, Clean)",
        "category": "nbdev",
        "icon": "$(package)"
      },
      {
        "command": "nbdev-mcp.test",
        "title": "Run Tests",
        "category": "nbdev",
        "icon": "$(beaker)"
      },
      {
        "command": "nbdev-mcp.lint",
        "title": "Lint Notebooks",
        "category": "nbdev",
        "icon": "$(checklist)"
      },
      {
        "command": "nbdev-mcp.refresh",
        "title": "Refresh",
        "category": "nbdev",
        "icon": "$(refresh)"
      },
      {
        "command": "nbdev-mcp.lintImports",
        "title": "Check Unused Imports",
        "category": "nbdev"
      },
      {
        "command": "nbdev-mcp.findSymbol",
        "title": "Find Symbol",
        "category": "nbdev"
      },
      {
        "command": "nbdev-mcp.analyzeExports",
        "title": "Analyze Notebook Exports",
        "category": "nbdev"
      },
      {
        "command": "nbdev-mcp.dependencyTree",
        "title": "Show Dependency Tree",
        "category": "nbdev"
      },
      {
        "command": "nbdev-mcp.modidxAudit",
        "title": "Audit Module Index",
        "category": "nbdev"
      },
      {
        "command": "nbdev-mcp.scanErrors",
        "title": "Scan Notebook Errors",
        "category": "nbdev"
      },
      {
        "command": "nbdev-mcp.runTutorials",
        "title": "Run Tutorials",
        "category": "nbdev"
      },
      {
        "command": "nbdev-mcp.findSourceNotebook",
        "title": "Find Source Notebook for Python File",
        "category": "nbdev"
      },
      {
        "command": "nbdev-mcp.checkIfGenerated",
        "title": "Check if File is Generated",
        "category": "nbdev"
      },
      {
        "command": "nbdev-mcp.lintDeadExports",
        "title": "Find Dead Exports",
        "category": "nbdev"
      },
      {
        "command": "nbdev-mcp.dependencyNotebook",
        "title": "Generate Dependency Notebook",
        "category": "nbdev"
      },
      {
        "command": "nbdev-mcp.generateApiDocs",
        "title": "Generate API Documentation",
        "category": "nbdev"
      },
      {
        "command": "nbdev-mcp.analyzeRemote",
        "title": "Analyze Remote Project",
        "category": "nbdev"
      },
      {
        "command": "nbdev-mcp.serverMetrics",
        "title": "Show Server Metrics",
        "category": "nbdev"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "nbdev-mcp.refresh",
          "when": "view == nbdev-project || view == nbdev-notebooks",
          "group": "navigation"
        },
        {
          "command": "nbdev-mcp.setProject",
          "when": "view == nbdev-project",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "nbdev-mcp.analyzeExports",
          "when": "view == nbdev-notebooks && viewItem == notebook",
          "group": "inline"
        }
      ],
      "editor/context": [
        {
          "command": "nbdev-mcp.findSourceNotebook",
          "when": "resourceExtname == .py",
          "group": "nbdev"
        },
        {
          "command": "nbdev-mcp.checkIfGenerated",
          "when": "resourceExtname == .py",
          "group": "nbdev"
        },
        {
          "command": "nbdev-mcp.analyzeExports",
          "when": "resourceExtname == .ipynb",
          "group": "nbdev"
        }
      ],
      "explorer/context": [
        {
          "command": "nbdev-mcp.findSourceNotebook",
          "when": "resourceExtname == .py",
          "group": "nbdev"
        },
        {
          "command": "nbdev-mcp.analyzeExports",
          "when": "resourceExtname == .ipynb",
          "group": "nbdev"
        }
      ]
    },
    "configuration": {
      "title": "nbdev MCP",
      "properties": {
        "nbdev-mcp.mcpServerPath": {
          "type": "string",
          "default": "",
          "description": "Path to nbdev-mcp server executable (leave empty to use system PATH)"
        },
        "nbdev-mcp.autoDetectProject": {
          "type": "boolean",
          "default": true,
          "description": "Automatically detect nbdev project from workspace"
        },
        "nbdev-mcp.showDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Show lint diagnostics in Problems panel"
        },
        "nbdev-mcp.lintOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run lint check when saving notebooks"
        }
      }
    },
    "problemMatchers": [
      {
        "name": "nbdev",
        "owner": "nbdev-mcp",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.*):(\\d+):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "message": 3
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {}
}
